# MUVON Ana Makine Konfigürasyonu
# Kopyala: cp .env.example .env  ve  gerekli alanları doldur
# Veya otomatik kurulum: curl -fsSL https://raw.githubusercontent.com/SaidMuratOzdemir/MUVON/main/install.sh | bash
#
# install.sh idempotent: tekrar çalıştırınca mevcut .env korunur,
# yalnız yeni eklenmiş env satırları sona eklenir. Aynı komut ile
# güncelleme yapılır.

# İmaj versiyonu için VERSION env'i kullanılmaz — image tag'i compose
# dosyasında sabit yazılır. install.sh --version X.Y.Z ile değiştirir
# (örn: bash <(curl -fsSL .../install.sh) --version 0.1.0).

# ── Veritabanı ───────────────────────────────────────────────────────────
# Güçlü rastgele şifre — install.sh otomatik üretir
POSTGRES_PASSWORD=

# ── MUVON ────────────────────────────────────────────────────────────────
# En az 32 karakter JWT imza anahtarı — install.sh otomatik üretir
MUVON_JWT_SECRET=

# AES-256-GCM şifreleme anahtarı.
# DB'deki gizli ayarları (SMTP password, vb) VE managed component'lerin
# secret env değişkenlerini şifreler.
#
# Bu anahtar ÜÇ yerde aynı olmak ZORUNDA:
#   1. central muvon (MUVON_ENCRYPTION_KEY)
#   2. muvon-deployer (MUVON_ENCRYPTION_KEY)
#   3. her edge agent (AGENT_ENCRYPTION_KEY)
#
# Aksi halde container'lar başlayamaz çünkü deployer secret env'leri
# decrypt edemez. Anahtarı kaybedersen veya değiştirirsen mevcut
# şifreli ayarlar ve container env secret'ları okunamaz olur — bu
# nedenle install.sh ilk kurulumda bir kez üretir, sonraki çalıştırma-
# larda asla overwrite etmez.
MUVON_ENCRYPTION_KEY=

# Admin panelinin sunulacağı domain — DNS bu sunucuya yönlendirilmiş olmalı
# Örn: muvon.example.com
MUVON_ADMIN_DOMAIN=

# ── Log ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Deployer (yönetilen uygulama deploy) ─────────────────────────────────
# Container poll aralığı; düşük değer = daha hızlı tepki, yüksek CPU
# MUVON_DEPLOYER_POLL_INTERVAL=5s

# ── Container Log Shipping (logship) ─────────────────────────────────────
# muvon-deployer her managed container'ın stdout/stderr akışını dialog-siem'e
# yollar. dialog-siem down ise yerel disk spool'a yazar, döndüğünde replay
# eder. Devre dışı bırakmak için "false" yapın.
# MUVON_DEPLOYER_LOGSHIP_ENABLED=true
#
# Spool disk bütçesi (bytes; varsayılan 256 MiB). Aşıldığında en eski
# container'ın spool'u atılır.
# MUVON_DEPLOYER_LOGSHIP_SPOOL_MAX_BYTES=268435456
