# Agent makine için — kopyala: cp .env.agent.example .env

GITHUB_REPO=SaidMuratOzdemir/MUVON
VERSION=latest

# Central muvon admin adresi
AGENT_CENTRAL_URL=https://central.example.com:9443

# Admin panelinden oluşturulan API key
AGENT_API_KEY=

# diaLOG log adresi (opsiyonel)
AGENT_LOG_ADDR=central.example.com:9001

LOG_LEVEL=info

# ── Container Log Shipping (dockerwatch) ─────────────────────────────────
# Agent host'undaki Docker container'larının stdout/stderr akışını central
# dialog-siem'e yollar (AGENT_LOG_ADDR kanalı üzerinden). Etkinleştirmek
# için docker-compose.agent.yml içindeki /var/run/docker.sock RO mount'unu
# uncomment edin ve aşağıdakileri açın.
# AGENT_DOCKERWATCH_ENABLED=true
# AGENT_HOST_ID=               # boş = "agent:<hostname>"
# AGENT_DOCKERWATCH_MANAGED_ONLY=false   # tüm container'lar yoksa sadece muvon.managed=true
