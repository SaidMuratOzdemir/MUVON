# Agent makine için — kopyala: cp .env.agent.example .env

GITHUB_REPO=SaidMuratOzdemir/MUVON
VERSION=latest

# Central muvon admin adresi
AGENT_CENTRAL_URL=https://central.example.com:9443

# Admin panelinden oluşturulan API key
AGENT_API_KEY=

# diaLOG log adresi (opsiyonel)
AGENT_LOG_ADDR=central.example.com:9001

LOG_LEVEL=info
